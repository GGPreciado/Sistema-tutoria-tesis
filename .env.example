# =============================================================
# Base de datos PostgreSQL
# =============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tutoria

# =============================================================
# Backend NestJS
# =============================================================
PORT=3000

# Token para el endpoint de exportación CSV (GET /admin/export).
# Cambiar a un valor secreto antes de la intervención experimental.
ADMIN_EXPORT_TOKEN=CAMBIA_ESTE_TOKEN_ANTES_DE_USAR

# =============================================================
# Frontend Angular
# Usado en src/environments/environment.ts (build-time)
# =============================================================
API_BASE_URL=http://localhost:3000
